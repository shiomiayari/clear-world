<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light"
    android:fitsSystemWindows="true">

    <!-- ヘッダー -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_clear_world"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:letterSpacing="0.03"
            android:fontFamily="sans-serif-light" />

        <ImageButton
            android:id="@+id/btn_stats"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_description_stats"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_description_settings"
            android:src="@android:drawable/ic_menu_preferences"
            app:tint="@color/text_primary"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- 水槽ビュー（カスタムView）-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp">

        <com.clearworld.ui.AquariumView
            android:id="@+id/view_aquarium"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Accessibility停止バナー -->
        <TextView
            android:id="@+id/banner_accessibility_stopped"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@color/warning_red"
            android:gravity="center"
            android:padding="10dp"
            android:text="@string/banner_accessibility_stopped"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:visibility="gone" />

    </androidx.cardview.widget.CardView>

    <!-- 魚セクション -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="6dp"
        android:text="@string/label_fish_section"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:letterSpacing="0.06" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_fish"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"
        android:orientation="horizontal" />

</LinearLayout>
